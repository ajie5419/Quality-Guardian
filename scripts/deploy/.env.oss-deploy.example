# OSS release root, artifacts will be uploaded to:
# ${OSS_RELEASE_PREFIX}/<VERSION>/backend-<VERSION>.tar.gz
# ${OSS_RELEASE_PREFIX}/<VERSION>/frontend-<VERSION>.tar.gz
# ${OSS_RELEASE_PREFIX}/<VERSION>/checksums-<VERSION>.txt
OSS_RELEASE_PREFIX=oss://your-bucket/quality-guardian/releases

# Local ossutil executable
OSSUTIL_BIN=ossutil

# SSH target
REMOTE_HOST=1.2.3.4
REMOTE_USER=root
REMOTE_SSH_KEY=~/.ssh/id_rsa

# Remote paths
SERVER_APP_DIR=/opt/qms
SERVER_RELEASE_DIR=/opt/qms/releases

# Docker image naming (choose one mode):
# Mode A (recommended for your current setup):
#   Single repo + prefixed tags:
#   backend image -> <IMAGE_REPO>:backend-<VERSION>
#   frontend image -> <IMAGE_REPO>:frontend-<VERSION>
IMAGE_REPO=crpi-jy3d0qwkxxv0twpn.cn-beijing.personal.cr.aliyuncs.com/ajie5419/qms

# Mode B (legacy compatibility, used when IMAGE_REPO is empty):
BACKEND_IMAGE_REPO=qg/backend
FRONTEND_IMAGE_REPO=qg/frontend

# Health check URL on server
HEALTHCHECK_URL=http://127.0.0.1:3000/api/status
