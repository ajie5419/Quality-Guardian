generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model inspections {
  id                  String              @id @default(cuid())
  serialNumber        String?             @unique
  category            inspection_category
  workOrderNumber     String
  projectName         String?
  supplierName        String?
  materialName        String?
  incomingType        String?
  processName         String?
  level1Component     String?
  level2Component     String?
  team                String?
  documents           String?
  packingListArchived String?
  quantity            Int                 @default(1)
  inspector           String
  inspectionDate      DateTime
  reportDate          DateTime?
  result              inspection_result   @default(PASS)
  remarks             String?             @db.Text
  isDeleted           Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  items               inspection_items[]
  work_order          work_orders         @relation(fields: [workOrderNumber], references: [workOrderNumber], onUpdate: Cascade)

  @@index([workOrderNumber])
  @@index([category])
  @@index([inspectionDate])
}

model inspection_items {
  id                 String            @id @default(cuid())
  inspectionId       String
  checkItem          String
  standardValue      String?
  upperTolerance     String?
  lowerTolerance     String?
  uom                String?
  acceptanceCriteria String?           @db.Text
  referenceDoc       String?
  measuredValue      String?
  result             inspection_result @default(PASS)
  remarks            String?
  order              Int               @default(0)
  inspection         inspections       @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

model menus {
  id        String   @id
  path      String?
  name      String?  @unique
  component String?
  redirect  String?
  meta      String?  @db.Text
  createdAt DateTime @default(now())
  status    Int      @default(1)
  type      String   @default("menu")
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  authCode  String?
  order     Int      @default(0)
  parentId  String?  @default("0")

  @@index([parentId])
}

model reports {
  id               String   @id @default(cuid())
  date             DateTime
  totalInspections Int      @default(0)
  passRate         Float    @default(0)
  majorDefects     Int      @default(0)
  minorDefects     Int      @default(0)
  status           String   @default("Draft")
  author           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model after_sales {
  id                  String                  @id
  serialNumber        Int
  occurDate           DateTime
  claimStatus         after_sales_claimStatus
  projectName         String
  productType         String?
  shipDate            DateTime?
  warrantyStatus      String?
  issueDescription    String?                 @db.Text
  quantity            Int
  feedbackDept        String?
  solution            String?                 @db.Text
  actualSolution      String?                 @db.Text
  qualityLoss         Decimal                 @default(0.00) @db.Decimal(10, 2)
  actualClaim         Decimal                 @default(0.00) @db.Decimal(10, 2)
  respDept            String?
  supplierBrand       String?
  photos              String?                 @db.LongText
  isClaim             Boolean                 @default(false)
  remarks             String?                 @db.Text
  failureType         String?
  failureCause        String?
  linkedEngineeringId String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  version             Int                     @default(1)
  isDeleted           Boolean                 @default(false)
  workOrderNumber     String
  customerName        String?
  location            String?
  factoryDate         DateTime?
  handler             String?
  materialCost        Decimal?                @default(0.00) @db.Decimal(10, 2)
  laborTravelCost     Decimal?                @default(0.00) @db.Decimal(10, 2)
  closeDate           DateTime?
  defectType          String?
  defectSubtype       String?
  severity            String?
  productSubtype      String?
  runningHours        Decimal?
  division            String?
  partName            String?
  work_orders         work_orders             @relation(fields: [workOrderNumber], references: [workOrderNumber], onUpdate: Cascade)

  @@index([claimStatus])
  @@index([occurDate])
  @@index([supplierBrand])
  @@index([workOrderNumber])
  @@index([projectName])
  @@index([isDeleted])
  @@index([respDept])
  @@index([defectType])
}

model audit_logs {
  id         String            @id @default(cuid())
  userId     String
  action     audit_logs_action
  targetType String
  targetId   String
  details    String?           @db.Text
  ipAddress  String?
  userAgent  String?
  timestamp  BigInt            @default(autoincrement())
  createdAt  DateTime          @default(now())
  users      users             @relation(fields: [userId], references: [id])

  @@index([timestamp])
  @@index([userId])
}

model login_logs {
  id        String   @id @default(cuid())
  username  String
  ip        String?
  browser   String?
  os        String?
  device    String?
  method    String?  @default("密码登录")
  status    String?  @default("成功") // 成功 / 失败
  message   String?  @db.Text
  createdAt DateTime @default(now())
}

model departments {
  id           String   @id
  name         String
  businessUnit String?
  description  String?
  status       Int      @default(1)
  parentId     String   @default("0")
  sort         Int      @default(0)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  version      Int      @default(1)

  @@index([parentId])
}

model dfmea_projects {
  id              String                @id @default(cuid())
  projectName     String
  workOrderId     String?
  version         String                @default("V1.0")
  status          String                @default("draft")
  description     String?               @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdBy       String                @default("admin")
  isDeleted       Boolean               @default(false)
  items           dfmea[]
  work_orders     work_orders?          @relation(fields: [workOrderId], references: [workOrderNumber], onUpdate: Cascade)
  task_dispatches qms_task_dispatches[]

  @@index([workOrderId])
  @@index([projectName])
  @@index([status])
}

model dfmea {
  id                String         @id @default(cuid())
  serialNumber      Int?
  item              String
  function          String?        @db.Text
  failureMode       String
  effect            String?        @db.Text
  severity          Int
  cause             String?        @db.Text
  occurrence        Int
  detection         Int
  rpn               Int
  preventionControl String?        @db.Text
  detectionControl  String?        @db.Text
  recommendedAction String?        @db.Text
  status            dfmea_status   @default(OPEN)
  responsibility    String?
  targetDate        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  version           Int            @default(1)
  isDeleted         Boolean        @default(false)
  order             Int            @default(0)
  projectId         String
  dfmea_projects    dfmea_projects @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model permissions {
  id          String   @id
  code        String   @unique
  name        String
  description String?
  module      String
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model project_boms {
  id                String      @id
  work_order_number String
  part_name         String
  part_number       String?
  material          String?
  quantity          Int         @default(1)
  unit              String      @default("pcs")
  remarks           String?     @db.Text
  created_by        String?
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt
  work_orders       work_orders @relation(fields: [work_order_number], references: [workOrderNumber], onUpdate: Cascade)

  @@index([work_order_number])
}

model bom_projects {
  id              String      @id @default(cuid())
  workOrderNumber String      @unique
  projectName     String
  status          String      @default("active")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isDeleted       Boolean     @default(false)
  work_order      work_orders @relation(fields: [workOrderNumber], references: [workOrderNumber], onUpdate: Cascade)
}

model doc_projects {
  id              String      @id @default(cuid())
  workOrderNumber String      @unique
  projectName     String
  status          String      @default("active")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isDeleted       Boolean     @default(false)
  work_order      work_orders @relation(fields: [workOrderNumber], references: [workOrderNumber], onUpdate: Cascade)
}

model quality_plans {
  id              String                   @id
  projectName     String
  customer        String
  documents       String?                  @db.LongText
  itpItems        String?                  @db.LongText
  planStatus      quality_plans_planStatus @default(DRAFT)
  preparedBy      String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  version         Int                      @default(1)
  isDeleted       Boolean                  @default(false)
  workOrderNumber String
  items           itp_items[]              @relation("PlanToItems")
  task_dispatches qms_task_dispatches[]
  work_orders     work_orders              @relation(fields: [workOrderNumber], references: [workOrderNumber], onUpdate: Cascade)

  @@index([planStatus])
  @@index([workOrderNumber])
}

model itp_items {
  id                 String        @id @default(cuid())
  projectId          String
  processStep        String
  activity           String
  controlPoint       String
  acceptanceCriteria String?       @db.Text
  referenceDoc       String?       @db.Text
  frequency          String?
  verifyingDocument  String?
  isQuantitative     Boolean       @default(false)
  quantitativeItems  String?       @db.LongText
  order              Int           @default(0)
  isDeleted          Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  quality_plan       quality_plans @relation("PlanToItems", fields: [projectId], references: [id])

  @@index([projectId])
  @@index([processStep])
}

model quality_records {
  id                                      String                      @id
  serialNumber                            Int
  date                                    DateTime
  status                                  quality_records_status
  partName                                String
  description                             String?                     @db.Text
  quantity                                Int
  lossHours                               Decimal                     @default(0.00) @db.Decimal(10, 2)
  lossAmount                              Decimal                     @default(0.00) @db.Decimal(10, 2)
  projectName                             String?
  division                                String?
  responsibleDepartment                   String
  responsibleBU                           String?
  inspector                               String?
  analysis                                String?                     @db.Text
  solution                                String?                     @db.Text
  issuePhoto                              String?                     @db.Text
  rectificationPhoto                      String?                     @db.Text
  isClaim                                 Boolean                     @default(false)
  nonConformanceNumber                    String?                     @unique
  lastEditor                              String?
  sourceAfterSalesId                      String?
  createdAt                               DateTime                    @default(now())
  updatedAt                               DateTime                    @updatedAt
  version                                 Int                         @default(1)
  isDeleted                               Boolean                     @default(false)
  workOrderNumber                         String?
  claimNotes                              String?                     @db.Text
  claimStatus                             quality_records_claimStatus @default(OPEN)
  recoveredAmount                         Decimal                     @default(0.00) @db.Decimal(10, 2)
  hourlyRate                              Decimal                     @default(0.00) @db.Decimal(10, 2)
  supplierName                            String?
  category                                String?
  processName                             String?
  defectType                              String?
  defectSubtype                           String?
  rootCause                               String?                     @db.Text
  severity                                String?
  users_quality_records_inspectorTousers  users?                      @relation("quality_records_inspectorTousers", fields: [inspector], references: [username])
  users_quality_records_lastEditorTousers users?                      @relation("quality_records_lastEditorTousers", fields: [lastEditor], references: [username])
  work_orders                             work_orders?                @relation(fields: [workOrderNumber], references: [workOrderNumber], onUpdate: Cascade)

  @@index([createdAt])
  @@index([date])
  @@index([inspector], map: "quality_records_inspector_fkey")
  @@index([lastEditor], map: "quality_records_lastEditor_fkey")
  @@index([partName])
  @@index([serialNumber])
  @@index([status])
  @@index([status, isDeleted])
  @@index([workOrderNumber])
  @@index([responsibleDepartment])
  @@index([defectType])
  @@index([processName])
}

model roles {
  id          String   @id
  name        String   @unique
  description String?
  permissions String   @db.LongText
  status      Int      @default(1)
  isSystem    Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       users[]
}

model sequences {
  name         String  @id
  currentValue Int     @default(0)
  prefix       String?
}

model standard_documents {
  id          String   @id
  name        String
  category    String
  path        String
  size        Int
  uploadedBy  String
  description String?  @db.Text
  tags        String   @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version     Int      @default(1)
  isDeleted   Boolean  @default(false)

  @@index([category])
  @@index([name])
  @@index([isDeleted])
}

model suppliers {
  id           String   @id @default(cuid())
  category     String?
  name         String   @unique
  productName  String?
  brand        String?
  origin       String?
  project      String?
  buyer        String?
  score2025    Float?
  contact      String?
  phone        String?
  email        String?
  address      String?
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  version      Int      @default(1)
  qualityScore Float    @default(100)
  rating       String   @default("A")
  status       String   @default("Qualified")

  @@index([status])
}

model system_settings {
  key         String   @id
  value       String?  @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

model users {
  id                                                String                @id
  username                                          String                @unique
  password                                          String
  email                                             String?
  realName                                          String?
  phone                                             String?
  roleId                                            String
  department                                        String
  status                                            users_status          @default(ACTIVE)
  avatar                                            String?
  isDeleted                                         Boolean               @default(false)
  createdAt                                         DateTime              @default(now())
  updatedAt                                         DateTime              @updatedAt
  version                                           Int                   @default(1)
  audit_logs                                        audit_logs[]
  qms_task_dispatches_assignee                      qms_task_dispatches[] @relation("qms_task_dispatches_assigneeIdTousers")
  qms_task_dispatches_assignor                      qms_task_dispatches[] @relation("qms_task_dispatches_assignorIdTousers")
  quality_records_quality_records_inspectorTousers  quality_records[]     @relation("quality_records_inspectorTousers")
  quality_records_quality_records_lastEditorTousers quality_records[]     @relation("quality_records_lastEditorTousers")
  roles                                             roles                 @relation(fields: [roleId], references: [id])

  @@index([roleId], map: "users_roleId_fkey")
}

model work_orders {
  workOrderNumber String             @id
  customerName    String
  projectName     String?
  division        String?
  quantity        Int
  deliveryDate    DateTime
  status          work_orders_status @default(OPEN)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  version         Int                @default(1)
  isDeleted       Boolean            @default(false)
  effectiveTime   DateTime?
  after_sales     after_sales[]
  bom_projects    bom_projects?
  dfmea_projects  dfmea_projects[]
  doc_projects    doc_projects?
  inspections     inspections[]
  project_boms    project_boms[]
  quality_plans   quality_plans[]
  quality_records quality_records[]

  @@index([customerName])
  @@index([deliveryDate])
  @@index([status])
}

model qms_task_dispatches {
  id                                          String          @id @default(cuid())
  type                                        String
  title                                       String
  level                                       Int             @default(1)
  itpProjectId                                String?
  dfmeaId                                     String?
  assignorId                                  String
  assigneeId                                  String
  status                                      String          @default("PENDING")
  priority                                    Int             @default(3)
  createdAt                                   DateTime        @default(now())
  updatedAt                                   DateTime        @updatedAt
  dueDate                                     DateTime?
  content                                     String?         @db.Text
  parentId                                    String?
  users_qms_task_dispatches_assigneeIdTousers users           @relation("qms_task_dispatches_assigneeIdTousers", fields: [assigneeId], references: [id])
  users_qms_task_dispatches_assignorIdTousers users           @relation("qms_task_dispatches_assignorIdTousers", fields: [assignorId], references: [id])
  dfmea_project                               dfmea_projects? @relation(fields: [dfmeaId], references: [id])
  itp_project                                 quality_plans?  @relation(fields: [itpProjectId], references: [id])

  @@index([assigneeId])
  @@index([assignorId], map: "qms_task_dispatches_assignorId_fkey")
  @@index([dfmeaId], map: "qms_task_dispatches_dfmeaId_fkey")
  @@index([itpProjectId], map: "qms_task_dispatches_itpProjectId_fkey")
}

model quality_losses {
  id          String   @id @default(cuid())
  lossId      String   @unique
  occurDate   DateTime
  type        String
  amount      Decimal  @default(0.00) @db.Decimal(10, 2)
  actualClaim Decimal  @default(0.00) @db.Decimal(10, 2)
  description String?  @db.Text
  respDept    String?
  status      String   @default("Pending")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model knowledge_categories {
  id          String           @id @default(cuid())
  name        String
  description String?          @db.Text
  sort        Int              @default(0)
  parentId    String?          @default("0")
  isDeleted   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       knowledge_base[]
}

model knowledge_base {
  id          String                @id @default(cuid())
  title       String
  summary     String?               @db.Text
  content     String?               @db.LongText
  categoryId  String?
  publishDate DateTime?
  tags        String?               @db.Text
  attachment  String?               @db.LongText
  isDeleted   Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  author      String?
  docId       String?               @unique
  status      String?               @default("Published")
  version     String?               @default("V1.0")
  category    knowledge_categories? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

model daily_reports {
  id        String   @id @default(cuid())
  date      DateTime
  reporter  String
  summary   String?  @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, reporter], name: "date_reporter")
}

enum inspection_category {
  INCOMING
  PROCESS
  SHIPMENT
}

enum inspection_result {
  PASS
  FAIL
  CONDITIONAL
  NA
}

enum audit_logs_action {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  BACKUP
  RESTORE
  EXPORT
}

enum quality_records_status {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  CLAIMING
}

enum after_sales_claimStatus {
  OPEN
  IN_PROGRESS
  SUBMITTED
  NEGOTIATING
  RESOLVED
  COMPLETED
  CLOSED
  CANCELLED
}

enum work_orders_status {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum quality_plans_planStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ACTIVE
  ARCHIVED
}

enum users_status {
  ACTIVE
  INACTIVE
  LOCKED
}

enum dfmea_status {
  OPEN
  IN_REVIEW
  APPROVED
  CLOSED
}

enum quality_records_claimStatus {
  OPEN
  IN_PROGRESS
  SUBMITTED
  NEGOTIATING
  RESOLVED
  COMPLETED
  CLOSED
  CANCELLED
}
